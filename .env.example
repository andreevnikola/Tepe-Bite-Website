# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRESQL_URL=postgresql://user:password@host:5432/tepebite
POSTGRES_SSL=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_SIZE=5

# ─── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://tepebite.com

# ─── SMTP (required for order confirmation emails) ─────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=hello@tepebite.com
SMTP_FROM_NAME=ТЕПЕ bite

# ─── Delivery pricing (EUR cents) ──────────────────────────────────────────────
# BASE_LOCKER_CENTS: base Speedy locker delivery price. Must be > 0 for checkout.
TEPE_DELIVERY_BASE_LOCKER_CENTS=230
# OFFICE_SURCHARGE_CENTS: extra charge for Speedy office vs locker. >= 0.
TEPE_DELIVERY_OFFICE_SURCHARGE_CENTS=100
# ADDRESS_SURCHARGE_CENTS: extra charge for home address delivery. >= 0.
TEPE_DELIVERY_ADDRESS_SURCHARGE_CENTS=230
# FREE_DELIVERY_THRESHOLD_CENTS: subtotal at which base locker delivery is free. Must be > 0.
TEPE_FREE_DELIVERY_THRESHOLD_CENTS=3000

# ─── Courier ───────────────────────────────────────────────────────────────────
# manual | speedy_api (mock refused in production)
COURIER_LOCATION_PROVIDER=manual
SPEEDY_API_CLIENT_ID=
SPEEDY_API_SECRET=

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_BOOTSTRAP_KEY=
SESSION_SECRET=

# ─── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ─── SMTP test (audit only, never commit a real address) ───────────────────────
# SMTP_TEST_RECIPIENT=your@email.com
