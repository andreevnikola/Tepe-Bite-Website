# ─── Database ──────────────────────────────────────────────────────────────────
# Neon/Postgres connection string used for orders.
POSTGRESQL_URL=postgresql://user:password@host:5432/tepebite
# Require SSL for the Postgres connection (true for hosted providers like Neon).
POSTGRES_SSL=true
# Whether to validate the server's SSL certificate. Set false only for local/dev DBs with self-signed certs.
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
# Max size of the Postgres connection pool.
DB_POOL_SIZE=5

# ─── App ───────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app, used to build absolute links (e.g. in emails).
APP_BASE_URL=https://tepebite.eu

# ─── MongoDB (admin dashboard — initiatives & partners, separate from Postgres orders) ──
# MongoDB Atlas connection string for the admin dashboard database.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/tepe_dashboard?appName=Primary
# Signing secret for admin session cookies. Generate a random string of 32+ chars.
SESSION_SECRET=

# ─── SMTP (required for order confirmation emails) ─────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=hello@tepebite.eu
SMTP_FROM_NAME=ТЕПЕ bite - барчето на Пловдив
# SMTP test (audit only, never commit a real address).
# SMTP_TEST_RECIPIENT=your@email.com

# ─── UploadThing & translation (admin dashboard image uploads + auto-translate) ─
# UploadThing API token, used to upload initiative/partner images.
UPLOADTHING_TOKEN=
# DeepL API key, used to auto-translate admin-entered content between BG/EN.
DEEPL_API_KEY=

# ─── Delivery pricing (EUR cents) ──────────────────────────────────────────────
# BASE_LOCKER_CENTS: base Speedy locker delivery price. Must be > 0 for checkout.
TEPE_DELIVERY_BASE_LOCKER_CENTS=230
# OFFICE_SURCHARGE_CENTS: extra charge for Speedy office vs locker. >= 0.
TEPE_DELIVERY_OFFICE_SURCHARGE_CENTS=100
# ADDRESS_SURCHARGE_CENTS: extra charge for home address delivery. >= 0.
TEPE_DELIVERY_ADDRESS_SURCHARGE_CENTS=230
# FREE_DELIVERY_THRESHOLD_CENTS: subtotal at which base locker delivery is free. Must be > 0.
TEPE_FREE_DELIVERY_THRESHOLD_CENTS=3000
# Same four values mirrored to the client bundle for UI display (must match the server-side values above).
NEXT_PUBLIC_TEPE_DELIVERY_BASE_LOCKER_CENTS=230
NEXT_PUBLIC_TEPE_DELIVERY_OFFICE_SURCHARGE_CENTS=100
NEXT_PUBLIC_TEPE_DELIVERY_ADDRESS_SURCHARGE_CENTS=230
NEXT_PUBLIC_TEPE_FREE_DELIVERY_THRESHOLD_CENTS=3000

# ─── Courier ───────────────────────────────────────────────────────────────────
# manual | speedy_api (mock refused in production)
COURIER_LOCATION_PROVIDER=manual
# Required when COURIER_LOCATION_PROVIDER=speedy_api.
SPEEDY_API_CLIENT_ID=
SPEEDY_API_SECRET=

# ─── Admin ─────────────────────────────────────────────────────────────────────
# One-time key used to bootstrap the first admin account.
ADMIN_BOOTSTRAP_KEY=

# ─── Orders feature flag ────────────────────────────────────────────────────────
# Whether the web checkout/orders flow is shown to visitors.
NEXT_PUBLIC_WEB_ORDERS_AVAILABLE=false

# ─── Telegram (optional — order notifications) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sanity CMS ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ─── ТЕПЕ bite Impact ────────────────────────────────────────────────────────────
# Google Form URL for campaign proposals. Empty → the "Propose a campaign" button
# falls back to Instagram/comments.
NEXT_PUBLIC_IMPACT_FORM_URL=
